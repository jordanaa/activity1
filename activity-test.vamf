{  "name":"Activity test",
   "shortDescription": "RM-396 - Verify startup/teardown tasks with parameter values specified in the activity manifest file",
   "icon":"customActivityManual.svg",
   "descriptionMarkdown":"Activity1.md",
   "priority":60,
   "topology": [
{
      "name": "Topology 1",
      "actionTitle":"Reserve",
      "description": "Create an immediate reservation on the topology",
      "reservationDuration":"",
      "automation": [
         {
            "testPath": "jordan1/testcases/parameters-tag-git.fftc",
            "allowToRunWithOptions": true,
            "parametersList":[
               {
                  "name": "manifestParam1",
                  "value": "testValue1",
                  "type": "TEXT",
                  "description": "Test Description" 
               }
            ]
         },
         {
            "testPath": "jordan1/testcases/parameters-tag-git.fftc",
            "allowToRunWithOptions": true,
            "name": "NewNameManifest",
            "parametersList": [
               {
                  "name": "manifestParam2",
                  "value": "testValue2",
                  "type": "TEXT",
                  "description": "Test Description" 
               }
            ]
         }
      ],
     "startupTasks": [
      {
        "testPath": "test-scm/testcases/parameters-tag-git.fftc",
        "parametersList": [
						{
							"name": "parameter1",
							"type": "INTEGER",
							"value": "27"
						}
					]
      }
      ],
    "teardownTasks": [
      {
        "testPath": "test-scm/testcases/parameters-tag-git.fftc",
        "parametersList": [
						{
							"name": "parameter1",
							"type": "INTEGER",
							"value": "27"
						},
						{
							"name": "parameter2",
							"type": "TEXT",
							"value": "testValue3"
						}
					]
      }
      ]
    }]
}
